# Required: YouTube Data API v3 KEY (starts with AIzaSy...)
# Google Cloud → APIs & Services → Credentials → Create credentials → API key
# NOT the OAuth Client ID (which ends in .apps.googleusercontent.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: OAuth Client ID (for future Google sign-in flows — not used in Phase 1)
GOOGLE_OAUTH_CLIENT_ID=

# Optional: Google Sheets sync (service account JSON path)
# Share your spreadsheet with the service account email before enabling.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=1B24KcqCYUWT3nJG6SF30LBKbkVBg1CUWaqUrjrkLsVc
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google-service-account.json

# Your output channel (Fill Viz) — used for reference in exports
OUTPUT_YOUTUBE_CHANNEL_ID=UClUZaCTA-gBR2iB8LKAAhNw

# Phase 2+: Vizard API (not required for Phase 1 discovery)
VIZARDAI_API_KEY=
